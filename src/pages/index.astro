---
import Layout from "../layouts/Layout.astro";

const navLinks = [
  { label: "O salonie", href: "#o-salonie" },
  { label: "Zabiegi", href: "#zabiegi" },
  { label: "Cennik", href: "#cennik" },
  { label: "Opinie", href: "#opinie" },
  { label: "Kontakt", href: "#kontakt" },
];

const services = {
  twarz: [
    { name: "Rytuał odmładzający", desc: "Głęboka regeneracja skóry z serum peptydowym", price: "320 zł", time: "75 min" },
    { name: "Mikrodermoabrazja diamentowa", desc: "Wygładzenie i rozjaśnienie cery z masażem", price: "280 zł", time: "60 min" },
    { name: "Mezoterapia igłowa", desc: "Intensywne nawilżenie i liftingowanie", price: "450 zł", time: "90 min" },
    { name: "Peeling chemiczny", desc: "Kwasy AHA/BHA — wyrównanie kolorytu", price: "260 zł", time: "50 min" },
    { name: "Laminacja brwi", desc: "Modelowanie i stylizacja łuków brwiowych", price: "180 zł", time: "45 min" },
    { name: "Lifting rzęs", desc: "Trwałe podkręcenie i wydłużenie rzęs", price: "150 zł", time: "60 min" },
  ],
  cialo: [
    { name: "Masaż Lomi Lomi", desc: "Hawajski masaż relaksacyjny ciałem i dłońmi", price: "380 zł", time: "90 min" },
    { name: "Rytuał Hammam", desc: "Peelingowanie, maska z gliny i masaż aromatyczny", price: "420 zł", time: "120 min" },
    { name: "Drenaż limfatyczny", desc: "Redukcja obrzęków i pobudzenie krążenia", price: "290 zł", time: "60 min" },
    { name: "Okłady algowe", desc: "Nawilżenie, mineralizacja i detoks skóry", price: "310 zł", time: "75 min" },
    { name: "Modelowanie sylwetki", desc: "Masaż antycellulitowy z olejkami", price: "260 zł", time: "60 min" },
    { name: "Masaż gorącymi kamieniami", desc: "Relaks i rozluźnienie głębokich napięć", price: "350 zł", time: "75 min" },
  ],
  dlonie: [
    { name: "Manicure klasyczny", desc: "Pielęgnacja i lakierowanie paznokci", price: "80 zł", time: "45 min" },
    { name: "Manicure hybrydowy", desc: "Hybryda — trwałość do 3 tygodni", price: "110 zł", time: "60 min" },
    { name: "Rytuał dłoni", desc: "Peeling, masaż, odżywcza maska i lakier", price: "160 zł", time: "75 min" },
    { name: "Pedicure SPA", desc: "Kąpiel ziołowa, peelingowanie, masaż stóp", price: "140 zł", time: "60 min" },
    { name: "Pedicure hybrydowy", desc: "Pielęgnacja z hybrydowym lakierem", price: "160 zł", time: "75 min" },
    { name: "Rytuał stóp", desc: "Luksusowy rytuał z maseczką i masażem łydek", price: "200 zł", time: "90 min" },
  ],
};

const reviews = [
  {
    name: "Magdalena W.",
    text: "Absolutnie wyjątkowe miejsce. Mezoterapia zmieniła moją skórę nie do poznania — po czterech wizytach wygląda jak po dziesięciu latach młodziej. Atmosfera jak w ekskluzywnym SPA paryskim.",
    service: "Mezoterapia igłowa",
    stars: 5,
  },
  {
    name: "Katarzyna B.",
    text: "Rytuał Lomi Lomi to najlepsze dwie godziny, jakie sobie sprawiłam od lat. Pani Marta ma wyjątkowy talent — po masażu poczułam się jakby ktoś zresetował moje ciało i umysł.",
    service: "Masaż Lomi Lomi",
    stars: 5,
  },
  {
    name: "Joanna K.",
    text: "Salon, który naprawdę dba o każdy detal. Białe orchidee, aromaterapia, herbata przed zabiegiem — czujesz się jak księżna. Manicure hybrydowy trzyma się perfekcyjnie już czwarty tydzień.",
    service: "Manicure hybrydowy",
    stars: 5,
  },
  {
    name: "Aleksandra M.",
    text: "Peeling chemiczny zrobiony bardzo profesjonalnie z pełnym omówieniem pielęgnacji. Widać, że kosmetyczki tu to ekspertki, nie tylko estetki. Wróciłam już trzy razy.",
    service: "Peeling chemiczny",
    stars: 5,
  },
];
---

<Layout
  title="Aura Beauty — Salon Kosmetyczny & SPA"
  description="Aura Beauty to ekskluzywny salon kosmetyczny i SPA w Warszawie. Oferujemy zabiegi na twarz, ciało, dłonie i stopy w wyjątkowej atmosferze luksusu."
>

  <!-- ===== NAWIGACJA ===== -->
  <header
    id="nav"
    class="fixed left-0 right-0 z-50 transition-all duration-500"
    style="background: transparent;"
  >
    <div class="px-7 lg:px-14 flex items-center justify-between h-16 lg:h-20">
      <!-- Logo -->
      <a href="#" class="flex items-baseline gap-3 group">
        <span class="text-xl lg:text-2xl italic" style="font-family: var(--font-display); font-weight: 400; color: var(--color-dark); letter-spacing: 0.02em;">Aura</span>
        <span class="text-xs tracking-[0.35em] uppercase pb-0.5" style="font-family: var(--font-mono); color: var(--color-taupe); font-size: 0.6rem;">Beauty</span>
      </a>

      <!-- Desktop nav — minimal, right-aligned -->
      <nav class="hidden lg:flex items-center gap-10">
        {navLinks.map((link) => (
          <a
            href={link.href}
            class="text-xs tracking-[0.2em] uppercase transition-colors duration-300 hover:opacity-60"
            style="font-family: var(--font-mono); color: var(--color-darksoft); font-size: 0.62rem;"
          >
            {link.label}
          </a>
        ))}
      </nav>

      <!-- CTA -->
      <a
        href="#rezerwacja"
        class="hidden lg:inline-flex items-center gap-2 px-6 py-2.5 text-xs tracking-widest uppercase transition-all duration-300 hover:opacity-80"
        style="background: var(--color-dark); color: var(--color-cream); font-family: var(--font-mono); font-size: 0.6rem; letter-spacing: 0.18em;"
      >
        Umów wizytę
      </a>

      <!-- Burger mobile -->
      <button
        id="burger"
        class="lg:hidden flex flex-col gap-1.5 p-2"
        aria-label="Menu"
      >
        <span class="block w-6 h-px" style="background: var(--color-dark);"></span>
        <span class="block w-4 h-px" style="background: var(--color-dark);"></span>
        <span class="block w-6 h-px" style="background: var(--color-dark);"></span>
      </button>
    </div>

    <!-- Mobile menu -->
    <div
      id="mobile-menu"
      class="hidden lg:hidden"
      style="background: var(--color-cream); border-top: 1px solid var(--color-line);"
    >
      <div class="px-7 py-8 flex flex-col gap-6">
        {navLinks.map((link) => (
          <a
            href={link.href}
            class="text-xs tracking-[0.3em] uppercase"
            style="font-family: var(--font-mono); color: var(--color-dark); font-size: 0.65rem;"
          >
            {link.label}
          </a>
        ))}
        <a
          href="#rezerwacja"
          class="inline-flex items-center justify-center px-7 py-3.5 text-xs tracking-widest uppercase mt-2"
          style="background: var(--color-dark); color: var(--color-cream); font-family: var(--font-mono); font-size: 0.6rem; letter-spacing: 0.18em;"
        >
          Umów wizytę
        </a>
      </div>
    </div>
  </header>

  <!-- ===== HERO — EDITORIAL ===== -->
  <section
    id="hero"
    class="relative overflow-hidden"
    style="background: var(--color-cream); min-height: 100svh;"
  >
    <!-- Thin left border line — editorial device -->
    <div class="absolute left-7 lg:left-14 top-0 bottom-0 w-px" style="background: var(--color-line); z-index: 2;"></div>

    <!-- Large background number — editorial ghost -->
    <div
      class="absolute select-none pointer-events-none"
      style="font-family: var(--font-display); font-weight: 700; font-size: clamp(18rem, 40vw, 52rem); line-height: 0.85; color: var(--color-line-light); right: -3vw; top: 50%; transform: translateY(-50%); z-index: 0; letter-spacing: -0.06em;"
      aria-hidden="true"
    >
      A
    </div>

    <!-- Hero image — positioned asymmetrically to the right -->
    <div
      class="absolute hidden lg:block"
      style="right: 6vw; top: 50%; transform: translateY(-50%); width: 36vw; z-index: 1;"
    >
      <div class="relative" style="border: 1px solid var(--color-nude);">
        <img
          src="https://images.unsplash.com/photo-1560750588-73207b1ef5b8?auto=format&fit=crop&w=900&q=80"
          alt="Aura Beauty — wnętrze salonu"
          style="width: 100%; height: 62vh; object-fit: cover; display: block; filter: saturate(0.88);"
        />
        <!-- Image caption -->
        <p
          class="absolute -bottom-6 right-0 text-right"
          style="font-family: var(--font-mono); font-size: 0.55rem; letter-spacing: 0.15em; color: var(--color-taupe); text-transform: uppercase;"
        >
          Salon · ul. Mokotowska 42, Warszawa
        </p>
      </div>
      <!-- Floating data tag — overlapping image -->
      <div
        class="absolute -left-10 bottom-16 px-5 py-4"
        style="background: var(--color-cream); border: 1px solid var(--color-nude); min-width: 130px; z-index: 3;"
      >
        <p style="font-family: var(--font-display); font-size: 2.6rem; font-weight: 500; color: var(--color-gold); line-height: 1;">12+</p>
        <p style="font-family: var(--font-mono); font-size: 0.52rem; letter-spacing: 0.18em; text-transform: uppercase; color: var(--color-taupe); margin-top: 4px;">Lat doświadczenia</p>
      </div>
    </div>

    <!-- Main editorial text -->
    <div
      class="relative flex flex-col justify-center"
      style="min-height: 100svh; padding: 12vw 7vw 10vw 7vw; z-index: 2; max-width: 58vw;"
    >
      <!-- Mono label -->
      <p
        class="reveal"
        style="font-family: var(--font-mono); font-size: 0.6rem; letter-spacing: 0.3em; text-transform: uppercase; color: var(--color-taupe); margin-bottom: 2.5rem;"
      >
        Salon Kosmetyczny &amp; SPA — Warszawa, 2012
      </p>

      <!-- GIANT display headline — breaks the grid -->
      <h1
        class="reveal reveal-delay-1"
        style="font-family: var(--font-display); font-weight: 300; font-size: clamp(5.5rem, 11vw, 13rem); line-height: 0.92; letter-spacing: -0.02em; color: var(--color-dark);"
      >
        Twoja<br/>
        skóra<br/>
        <em style="font-weight: 500; color: var(--color-gold); font-style: italic; font-size: clamp(6rem, 12.5vw, 15rem);">zasługuje</em><br/>
        na luksus.
      </h1>

      <!-- Rule line + desc — asymmetric indent -->
      <div class="reveal reveal-delay-2" style="margin-top: 3.5rem; display: flex; align-items: flex-start; gap: 2rem;">
        <div style="width: 1px; height: 56px; background: var(--color-gold); flex-shrink: 0; margin-top: 4px;"></div>
        <p style="font-family: var(--font-body); font-weight: 300; font-size: 1rem; line-height: 1.75; color: var(--color-darksoft); max-width: 380px;">
          Odkryj rytuały piękna tworzone z myślą o Tobie. Profesjonalne zabiegi, które odnawiają, relaksują i rozświetlają.
        </p>
      </div>

      <!-- CTA row -->
      <div class="reveal reveal-delay-3" style="margin-top: 3rem; display: flex; align-items: center; gap: 2.5rem; flex-wrap: wrap;">
        <a
          href="#rezerwacja"
          style="display: inline-flex; align-items: center; gap: 10px; background: var(--color-dark); color: var(--color-cream); padding: 1rem 2.25rem; font-family: var(--font-mono); font-size: 0.6rem; letter-spacing: 0.2em; text-transform: uppercase; transition: opacity 0.3s; text-decoration: none;"
          onmouseover="this.style.opacity='0.8'"
          onmouseout="this.style.opacity='1'"
        >
          Umów wizytę <span style="color: var(--color-blush); font-size: 1rem; line-height: 1;">→</span>
        </a>
        <a
          href="#zabiegi"
          style="font-family: var(--font-mono); font-size: 0.6rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(--color-taupe); text-decoration: none; border-bottom: 1px solid var(--color-nude); padding-bottom: 2px; transition: color 0.3s;"
        >
          Poznaj zabiegi
        </a>
      </div>

      <!-- Scroll line -->
      <div class="reveal reveal-delay-5" style="position: absolute; bottom: 4rem; left: 7vw; display: flex; flex-direction: column; align-items: center; gap: 8px;">
        <div style="width: 1px; height: 48px; background: var(--color-nude); overflow: hidden; position: relative;">
          <div class="scroll-line-inner" style="width: 100%; height: 50%; background: var(--color-gold);"></div>
        </div>
        <p style="font-family: var(--font-mono); font-size: 0.5rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(--color-taupe);">Scroll</p>
      </div>
    </div>

    <!-- Mobile image (below text on small screens) -->
    <div class="block lg:hidden px-7 pb-16">
      <div style="border: 1px solid var(--color-nude);">
        <img
          src="https://images.unsplash.com/photo-1560750588-73207b1ef5b8?auto=format&fit=crop&w=900&q=80"
          alt="Aura Beauty — wnętrze salonu"
          style="width: 100%; height: 56vw; object-fit: cover; display: block; filter: saturate(0.88);"
        />
      </div>
    </div>
  </section>

  <!-- ===== O SALONIE — Section 01 ===== -->
  <section id="o-salonie" class="relative" style="background: var(--color-cream); padding: 10vw 0;">
    <!-- Section number — editorial device, enormous ghost -->
    <div class="absolute select-none pointer-events-none" aria-hidden="true" style="left: 0; top: -4vw; font-family: var(--font-display); font-weight: 700; font-size: clamp(12rem, 28vw, 36rem); line-height: 1; color: var(--color-line-light); letter-spacing: -0.05em; z-index: 0;">01</div>

    <div class="relative" style="z-index: 1; padding: 0 7vw;">

      <!-- Asymmetric two-column layout: text left, image right but shifted up/overlapping -->
      <div class="grid lg:grid-cols-12 gap-0 items-start">

        <!-- Left column: section label + main text -->
        <div class="lg:col-span-6 lg:col-start-1 reveal-left">
          <!-- Mono category label -->
          <div style="display: flex; align-items: center; gap: 1rem; margin-bottom: 2rem;">
            <span style="font-family: var(--font-mono); font-size: 0.58rem; letter-spacing: 0.3em; text-transform: uppercase; color: var(--color-gold);">01 — O nas</span>
            <div style="flex: 1; height: 1px; background: var(--color-line); max-width: 80px;"></div>
          </div>

          <h2
            style="font-family: var(--font-display); font-weight: 300; font-size: clamp(3.2rem, 6vw, 7rem); line-height: 1.0; letter-spacing: -0.02em; color: var(--color-dark); margin-bottom: 2.5rem;"
          >
            Piękno w każdym<br/>
            <em style="font-weight: 600; font-style: italic;">szczególe.</em>
          </h2>

          <p style="font-family: var(--font-body); font-weight: 300; font-size: 1.05rem; line-height: 1.85; color: var(--color-darksoft); margin-bottom: 1.5rem; max-width: 480px;">
            Aura Beauty to miejsce, gdzie czas zatrzymuje się w biegu — kameralny salon z duszą, w którym każda wizyta jest starannie zaplanowanym rytuałem. Działamy w sercu Warszawy od 2012 roku.
          </p>
          <p style="font-family: var(--font-body); font-weight: 300; font-size: 1.05rem; line-height: 1.85; color: var(--color-darksoft); max-width: 480px;">
            Nasz zespół to certyfikowane kosmetyczki i terapeutki SPA, które łączą wiedzę medyczną z artystycznym podejściem do piękna. Używamy wyłącznie preparatów premium: La Mer, Biologique Recherche i Sisley.
          </p>

          <!-- Stats row — editorial number display -->
          <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 0; margin-top: 3.5rem; border-top: 1px solid var(--color-line); border-left: 1px solid var(--color-line);">
            {[
              { n: "4000+", label: "Zadowolonych klientek" },
              { n: "12+", label: "Lat doświadczenia" },
              { n: "30+", label: "Zabiegów w menu" },
            ].map((stat) => (
              <div style="padding: 1.5rem 1.25rem; border-right: 1px solid var(--color-line); border-bottom: 1px solid var(--color-line);">
                <p style="font-family: var(--font-display); font-size: clamp(1.8rem, 3vw, 2.8rem); font-weight: 500; color: var(--color-dark); line-height: 1;">{stat.n}</p>
                <p style="font-family: var(--font-mono); font-size: 0.54rem; letter-spacing: 0.18em; text-transform: uppercase; color: var(--color-taupe); margin-top: 6px;">{stat.label}</p>
              </div>
            ))}
          </div>
        </div>

        <!-- Right column: image, shifted upward / overlapping -->
        <div
          class="lg:col-span-5 lg:col-start-8 reveal-right"
          style="margin-top: -6vw;"
        >
          <div style="position: relative;">
            <!-- Decorative thin frame offset -->
            <div style="position: absolute; inset: -12px 12px 12px -12px; border: 1px solid var(--color-line); z-index: 0; pointer-events: none;"></div>
            <div style="position: relative; z-index: 1; border: 1px solid var(--color-nude);">
              <img
                src="https://images.unsplash.com/photo-1570172619644-dfd03ed5d881?auto=format&fit=crop&w=800&q=80"
                alt="Zabieg w Aura Beauty"
                style="width: 100%; height: 520px; object-fit: cover; display: block; filter: saturate(0.85);"
              />
            </div>
            <!-- Mono caption tag -->
            <p style="font-family: var(--font-mono); font-size: 0.52rem; letter-spacing: 0.15em; text-transform: uppercase; color: var(--color-taupe); margin-top: 0.75rem; text-align: right;">Gabinet zabiegowy — Aura Beauty</p>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ===== ZABIEGI — Section 02 ===== -->
  <section
    id="zabiegi"
    class="relative"
    style="background: var(--color-offblack); padding: 10vw 0; overflow: hidden;"
  >
    <!-- Ghost "02" -->
    <div class="absolute select-none pointer-events-none" aria-hidden="true" style="right: -2vw; top: -4vw; font-family: var(--font-display); font-weight: 700; font-size: clamp(12rem, 28vw, 36rem); line-height: 1; color: color-mix(in srgb, #fff 4%, transparent); letter-spacing: -0.05em; z-index: 0;">02</div>

    <div class="relative" style="z-index: 1; padding: 0 7vw;">

      <!-- Section header — left-aligned, editorial -->
      <div class="reveal" style="margin-bottom: 5rem;">
        <div style="display: flex; align-items: center; gap: 1rem; margin-bottom: 2rem;">
          <span style="font-family: var(--font-mono); font-size: 0.58rem; letter-spacing: 0.3em; text-transform: uppercase; color: var(--color-gold);">02 — Menu zabiegów</span>
          <div style="flex: 1; height: 1px; background: color-mix(in srgb, var(--color-gold) 25%, transparent); max-width: 80px;"></div>
        </div>
        <div class="grid lg:grid-cols-2 gap-8 items-end">
          <h2
            style="font-family: var(--font-display); font-weight: 300; font-size: clamp(3rem, 6vw, 7rem); line-height: 0.95; letter-spacing: -0.02em; color: var(--color-cream);"
          >
            Rytuały dla<br/>
            ciała <em style="font-weight: 600; font-style: italic; color: var(--color-blush);">i ducha.</em>
          </h2>
          <p style="font-family: var(--font-body); font-weight: 300; font-size: 1rem; line-height: 1.8; color: color-mix(in srgb, var(--color-cream) 55%, transparent); max-width: 400px;">
            Każdy zabieg to unikalne doświadczenie zmysłowe — zaprojektowane, żebyś wyszła odmieniona.
          </p>
        </div>
      </div>

      <!-- Tabs — minimal mono style -->
      <div id="tabs" class="reveal reveal-delay-1" style="display: flex; gap: 0; margin-bottom: 3rem; border: 1px solid color-mix(in srgb, var(--color-taupe) 30%, transparent); width: fit-content;">
        {[
          { id: "twarz", label: "Twarz" },
          { id: "cialo", label: "Ciało" },
          { id: "dlonie", label: "Dłonie & Stopy" },
        ].map((tab, i) => (
          <button
            data-tab={tab.id}
            class={`tab-btn ${i === 0 ? "tab-active" : ""}`}
            style={i === 0
              ? "background: var(--color-gold); color: var(--color-dark); border: none; padding: 0.7rem 1.75rem; font-family: var(--font-mono); font-size: 0.58rem; letter-spacing: 0.2em; text-transform: uppercase; cursor: pointer;"
              : "background: transparent; color: color-mix(in srgb, var(--color-cream) 50%, transparent); border: none; border-left: 1px solid color-mix(in srgb, var(--color-taupe) 30%, transparent); padding: 0.7rem 1.75rem; font-family: var(--font-mono); font-size: 0.58rem; letter-spacing: 0.2em; text-transform: uppercase; cursor: pointer;"}
          >
            {tab.label}
          </button>
        ))}
      </div>

      <!-- Services — editorial ROWS not grid cards -->
      {["twarz", "cialo", "dlonie"].map((cat, catIdx) => (
        <div
          id={`panel-${cat}`}
          class={`tab-panel ${catIdx !== 0 ? "hidden" : ""}`}
        >
          {(services as any)[cat].map((s: any, i: number) => (
            <div
              class={`reveal reveal-delay-${Math.min(i + 1, 5)} service-row`}
              style="display: grid; grid-template-columns: 2.5rem 1fr auto auto; align-items: center; gap: 1.5rem 2rem; padding: 1.5rem 0; border-bottom: 1px solid color-mix(in srgb, var(--color-taupe) 18%, transparent); transition: background 0.2s;"
            >
              <!-- Index -->
              <span style="font-family: var(--font-mono); font-size: 0.52rem; letter-spacing: 0.15em; color: color-mix(in srgb, var(--color-taupe) 50%, transparent);">
                {String(i + 1).padStart(2, "0")}
              </span>
              <!-- Name + desc -->
              <div>
                <p style="font-family: var(--font-display); font-weight: 400; font-size: clamp(1.1rem, 2vw, 1.5rem); color: var(--color-cream); margin-bottom: 2px;">{s.name}</p>
                <p style="font-family: var(--font-body); font-weight: 300; font-size: 0.82rem; color: color-mix(in srgb, var(--color-cream) 40%, transparent);">{s.desc}</p>
              </div>
              <!-- Time -->
