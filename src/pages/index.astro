  <!-- ===== SCRIPTS ===== -->
  <script>
    // Tab switcher
    const tabBtns = document.querySelectorAll<HTMLButtonElement>(".tab-btn");
    const tabPanels = document.querySelectorAll<HTMLElement>(".tab-panel");

    tabBtns.forEach((btn) => {
      btn.addEventListener("click", () => {
        const target = btn.dataset.tab;
        tabBtns.forEach((b) => {
          const isActive = b === btn;
          b.style.cssText = isActive
            ? "background: var(--color-gold); color: var(--color-dark); border: none; padding: 0.7rem 1.75rem; font-family: var(--font-mono); font-size: 0.58rem; letter-spacing: 0.2em; text-transform: uppercase; cursor: pointer;"
            : "background: transparent; color: color-mix(in srgb, var(--color-cream) 50%, transparent); border: none; border-left: 1px solid color-mix(in srgb, var(--color-taupe) 30%, transparent); padding: 0.7rem 1.75rem; font-family: var(--font-mono); font-size: 0.58rem; letter-spacing: 0.2em; text-transform: uppercase; cursor: pointer;";
        });
        tabPanels.forEach((panel) => {
          if (panel.id === `panel-${target}`) {
            panel.classList.remove("hidden");
            panel.querySelectorAll<HTMLElement>(".reveal").forEach((el) => {
              if (!el.classList.contains("is-visible")) el.classList.add("is-visible");
            });
          } else {
            panel.classList.add("hidden");
          }
        });
      });
    });

    // Form confirmation
    const form = document.getElementById("booking-form");
    const confirmation = document.getElementById("form-confirmation");
    form?.addEventListener("submit", (e) => {
      e.preventDefault();
      form.classList.add("hidden");
      confirmation?.classList.remove("hidden");
    });

    // Show time column on medium+ screens
    const mq = window.matchMedia("(min-width: 768px)");
    function showTimes(matches: boolean) {
      document.querySelectorAll<HTMLElement>(".md-show").forEach(el => {
        el.style.display = matches ? "block" : "none";
      });
    }
    showTimes(mq.matches);
    mq.addEventListener("change", (e) => showTimes(e.matches));
  </script>

